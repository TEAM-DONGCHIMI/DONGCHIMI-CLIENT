{
  "name": "@dongchimi/design-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "**/*.css.ts"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./icons": "./src/icons/index.ts",
    "./styles": "./src/styles/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "check:icons": "node scripts/check-icons.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:integration": "vitest run --project integration --passWithNoTests",
    "test:unit": "vitest run --project unit --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vanilla-extract/recipes": "catalog:",
    "clsx": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@dongchimi/eslint-config": "workspace:*",
    "@dongchimi/typescript-config": "workspace:*",
    "@svgr/cli": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vanilla-extract/css": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
