{
  "name": "@dongchimi/design-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "**/*.css.ts"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./icons": "./src/icons/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "check:icons": "node scripts/check-icons.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@dongchimi/eslint-config": "workspace:*",
    "@dongchimi/typescript-config": "workspace:*",
    "@svgr/cli": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vanilla-extract/css": "catalog:",
    "eslint": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:"
  }
}
