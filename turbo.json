{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": [
    "VITE_PUBLIC_API_SERVER_BASE_URL",
    "VITE_PUBLIC_CLIENT_BASE_URL",
    "VITE_PUBLIC_KAKAO_MAP_APP_KEY",
    "VITE_PUBLIC_S3_BASE_URL",
    "VITE_SENTRY_DSN",
    "VITE_SENTRY_ENVIRONMENT",
    "VITE_SENTRY_RELEASE"
  ],
  "globalPassThroughEnv": ["API_BASE_URL", "KAKAO_REST_API_KEY", "KAKAO_REDIRECT_URI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"]
    },
    "@dongchimi/design-system#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@dongchimi/shared#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:coverage": {
      "dependsOn": ["^test:coverage"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["^test:integration"]
    },
    "test:unit": {
      "dependsOn": ["^test:unit"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
